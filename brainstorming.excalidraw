    {
      "id": "lQZquM5fBLpnUwKgUgW19",
      "type": "text",
      "x": 2929.6200693102905,
      "y": 2324.5435993993806,
      "width": 925.9762799702414,
      "height": 472.04433497537104,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1z",
      "roundness": null,
      "seed": 519227392,
      "version": 287,
      "versionNonce": 436783104,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772717279143,
      "link": null,
      "locked": false,
      "text": "Current rescue models rely on high-bandwidth cloud\nconnectivity for processing and coordination. When\ninfrastructure collapses, these centralized systems\nfail. There is an urgent need for an Autonomous\nCommand Agent that can operate at the edge to\norchestrate a fleet of rescue drones. This system\nmust be capable of mapping disaster zones, detecting\nsurvivors using on-device AI, and efficiently managing\ndrone resources through a standardized Model\nContext Protocol (MCP) to ensure aid reaches\nsurvivors even without human pilots or cloud access.",
      "fontSize": 34.33049708911789,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Current rescue models rely on high-bandwidth cloud connectivity for processing and coordination. When infrastructure collapses, these centralized systems fail. There is an urgent need for an Autonomous Command Agent that can operate at the edge to orchestrate a fleet of rescue drones. This system must be capable of mapping disaster zones, detecting survivors using on-device AI, and efficiently managing drone resources through a standardized Model Context Protocol (MCP) to ensure aid reaches survivors even without human pilots or cloud access.",
      "autoResize": false,
      "lineHeight": 1.25
    },
